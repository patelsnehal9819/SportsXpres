  "description": "Smart Sports Shopping Made Simple - Full Stack MERN Application",
  "main": "index.js",
  "scripts": {
    "start": "concurrently \"npm run backend\" \"npm run frontend\"",
    "backend": "cd sportsxpress-backend && npm run dev",
    "frontend": "cd sportsxpress-frontend && npm start",
    "install-all": "npm install && cd sportsxpress-backend && npm install && cd ../sportsxpress-frontend && npm install",
    "build": "cd sportsxpress-frontend && npm run build",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
